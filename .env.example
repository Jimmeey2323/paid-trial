# Google Sheets API Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_SPREADSHEET_ID=your_google_spreadsheet_id
GOOGLE_SHEET_NAME=Website

# Momence Lead Capture
MOMENCE_API_TOKEN=your_momence_api_token
MOMENCE_SOURCE_ID=your_momence_source_id
MOMENCE_LEAD_ENDPOINT=https://api.momence.com/integrations/customer-leads/your_account_id/collect
FORM_API_BASE_URL=
FORM_SCHEDULE_URL=https://momence.com/u/your-schedule-path
FORM_REDIRECT_URL=https://momence.com/u/your-redirect-path

# Supabase database storage (optional)
# Use the project URL and the server-side service role key from Supabase.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_DB_SCHEMA=public
SUPABASE_SUBMISSIONS_TABLE=physique57_trial_form_submissions
SUPABASE_PARTIALS_TABLE=physique57_trial_form_partials

# Supabase Edge Function for Momence sessions
SUPABASE_MOMENCE_SESSIONS_URL=https://your-project.supabase.co/functions/v1/momence-sessions
SUPABASE_MOMENCE_SESSIONS_KEY=your_supabase_edge_function_key
SCHEDULE_LOOKAHEAD_DAYS=30

# Public Tracking Configuration
GA_MEASUREMENT_ID=your_google_analytics_measurement_id
GOOGLE_ADS_ID=your_google_ads_id
GOOGLE_ADS_CONVERSION_LABEL=your_google_ads_conversion_label
GOOGLE_ADS_CONVERSION_VALUE=1
GOOGLE_ADS_CONVERSION_CURRENCY=INR
META_PIXEL_ID=your_meta_pixel_id
META_CONVERSIONS_ACCESS_TOKEN=your_meta_conversions_access_token
META_TEST_EVENT_CODE=optional_meta_test_event_code
SNAP_PIXEL_ID=your_snap_pixel_id
GTM_ID=your_gtm_id

# Server Configuration
PORT=3000
